{
  "name": "Student",
  "type": "object",
  "properties": {
    "name": {
      "type": "string",
      "title": "Student Name"
    },
    "tutor_email": {
      "type": "string",
      "title": "Tutor Email"
    },
    "current_phase": {
      "type": "number",
      "title": "Current Phase",
      "default": 1
    },
    "current_session": {
      "type": "number",
      "title": "Current Session",
      "default": 1
    },
    "placement_completed": {
      "type": "boolean",
      "title": "Placement Completed",
      "default": false
    },
    "placement_score": {
      "type": "number",
      "title": "Placement Score"
    },
    "last_session_date": {
      "type": "string",
      "title": "Last Session Date"
    },
    "graduated": {
      "type": "boolean",
      "title": "Graduated",
      "default": false
    },
    "avatar_color": {
      "type": "string",
      "title": "Avatar Color",
      "default": "#10b981"
    }
  },
  "required": [
    "name",
    "tutor_email"
  ]
}